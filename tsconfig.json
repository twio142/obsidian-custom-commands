{
  "compilerOptions": {
    "target": "ES6",
    "lib": [
      "DOM",
      "ES5",
      "ES6",
      "ES7"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "allowJs": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "importHelpers": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "isolatedModules": true
  },
  "include": [
    "**/*.ts"
  ]
}
